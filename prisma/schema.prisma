// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Asset {
  id            String   @id @default(uuid())
  name          String
  type          String   // Residencial, Comercial, Terreno, Industrial
  
  // Address
  address       String?  // Full address string for display
  zipCode       String?
  street        String?
  number        String?
  complement    String?
  neighborhood  String?
  city          String?
  state         String?
  description   String?  // Full extracted description

  // Characteristics
  areaPrivative Decimal?
  areaTotal     Decimal?
  bedrooms      Int?
  suites        Int?
  bathrooms     Int?
  parkingSpaces Int?

  // Documentation
  matricula         String?
  iptuRegistration  String?                      // Inscrição municipal (ex: 03.09.043.0273.175)
  iptuValue         Decimal? @default(0)         // Valor mensal ou anual do IPTU em R$
  iptuFrequency     String? @default("monthly")  // monthly or annual
  condominio        String? // Novo Campo
  registryOffice    String?
  acquisitionDate   String? // ISO Date string
  irpfStatus        String? // Declarado, Pendente, Isento
  acquisitionOrigin String?

  // Financial
  value                 Decimal @default(0) // Acquisition Value
  marketValue           Decimal @default(0)
  declaredValue         Decimal?
  saleForecast          String?
  suggestedRentalValue  Decimal?
  rentalValue           Decimal @default(0)
  
  status        String   @default("Vago") // Locado, Vago, Em Reforma, Uso Próprio
  image         String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  partners      AssetPartner[]
  financing     Financing?
  leases        Lease[]
  contracts     Contract[]
}

model AssetPartner {
  id          String @id @default(uuid())
  assetId     String
  asset       Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  
  name        String // Storing directly for simplicity as per current frontend usage
  initials    String
  color       String
  percentage  Decimal

  @@index([assetId])
}

model Financing {
  id                    String @id @default(uuid())
  assetId               String @unique
  asset                 Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  valorTotal            Decimal
  subtotalConstrutora   Decimal
  valorFinanciar        Decimal
  valorQuitado          Decimal?
  saldoDevedor          Decimal?
  
  dataAssinatura        String?
  vencimentoConstrutora String?
  vencimentoPrimeira    String?
  prazoMeses            String?
  jurosAnuais           String?
  indexador             String?
  sistemaAmortizacao    String?
  taxaAdm               String?
  seguros               String?
  
  // Complex nested objects stored as JSON
  phases               String? // JSON string for checkpoits/phases
  cashFlow             String? // JSON string for CashFlowItems
}

model Lease {
  id              String @id @default(uuid())
  assetId         String
  asset           Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  nomeInquilino   String
  documentoInquilino String?
  emailInquilino     String?
  valorAluguel    Decimal
  diaVencimento   Int
  inicioVigencia  String?
  fimContrato     String?
  garantia        String?
  indexador       String?
  contractFile    String? // JSON or URL

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([assetId])
}

model Invoice {
  id              String   @id @default(uuid())
  data            String?
  cnpj_cpf_emissor String?
  nome_emissor    String?
  endereco_emissor String?
  cidade          String?
  estado          String?
  valor_total     Decimal?
  categoria       String?
  status          String   @default("PENDENTE") // APROVADO, PENDENTE
  source          String?  // Upload, Gmail
  fileCopy        String?  // Base64 or URL
  auditReason     String?
  items           String?  // JSON string for line items
  numero_nota      String?
  serie_nota       String?
  beneficiario     String?
  nome_tomador     String?
  cpf_cnpj_tomador String?
  endereco_tomador String?
  email_tomador    String?
  telefone_emissor String?
  telefone_tomador String?
  
  // Structured Address - Emissor
  cep_emissor        String?
  logradouro_emissor String?
  numero_emissor     String?
  bairro_emissor     String?
  complemento_emissor String?

  // Structured Address - Tomador
  cep_tomador        String?
  logradouro_tomador String?
  numero_tomador     String?
  bairro_tomador     String?
  complemento_tomador String?
  cidade_tomador     String?
  estado_tomador     String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([categoria])
  @@index([createdAt])
    @@index([numero_nota])
}

// --- RENTAL MANAGEMENT MODULE ---

model Tenant {
  id        String   @id @default(uuid())
  name      String
  document  String?  @unique // CPF or CNPJ
  email     String?
  phone     String?
  createdAt DateTime @default(now())

  contracts Contract[]
  aliases   TenantAlias[]
}

model Contract {
  id              String   @id @default(uuid())
  contractNumber  String?  @unique // Human readable ID e.g. CTR-2026-001
  assetId         String
  asset           Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  startDate       DateTime
  durationMonths  Int      @default(12)
  baseValue       Decimal
  currentValue    Decimal
  adjustmentIndex String?  @default("IPCA")
  dueDay          Int
  penaltyPercent  Decimal  @default(10.0)
  status          String   @default("active") // active, suspended, finished
  lastAdjustment  DateTime?

  payments        PaymentHistory[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([assetId])
  @@index([tenantId])
  @@index([status])
    @@index([dueDate])
}

model TenantAlias {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aliasName String
  lastUsed  DateTime?
  confidence Float   @default(1.0)
  createdAt DateTime @default(now())

  @@unique([tenantId, aliasName])
}

model PaymentHistory {
  id             String    @id @default(uuid())
  contractId     String
  contract       Contract  @relation(fields: [contractId], references: [id])
  dueDate        DateTime
  paymentDate    DateTime?
  expectedValue  Decimal
  paidValue      Decimal?
  status         String    @default("pending") // pending, paid, partial, overdue
  method         String    @default("PIX")
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([contractId])
  @@index([status])
    @@index([dueDate])
}

model SystemAuditLog {
  id        String   @id @default(uuid())
  action    String   // e.g., "CREATE", "UPDATE", "DELETE", "LEARN_ALIAS"
  entity    String   // e.g., "Asset", "Contract", "TenantAlias"
  entityId  String   // ID of the modified entity
  actorName String   // Name of user (fixed as "Ricardo Silva" or "System" for MVP)
  details   String?  // JSON or human-readable summary of change
  createdAt DateTime @default(now())

  @@index([entity, entityId])
}

// --- AUTHENTICATION MODULE (Auth.js) ---

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // USER, ADMIN
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

